# MyPocket config. Copy to .env and fill in.

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///data/mypocket.db

# --- Teller (Citi auto-sync) ---
# Sign up at https://teller.io, download teller.zip (cert + key)
TELLER_APPLICATION_ID=app_xxxxxxxxxxxxxxxxxxxxx
TELLER_ENVIRONMENT=development
TELLER_CERT_PATH=teller/certificate.pem
TELLER_KEY_PATH=teller/private_key.pem

# --- E*TRADE (brokerage + Roth auto-sync) ---
# Apply at https://developer.etrade.com/getting-started
# Sandbox keys arrive in ~2-5 business days, production a bit longer.
# When you get the email with your keys, paste them here.
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_ENVIRONMENT=sandbox  # switch to "production" when prod keys arrive
